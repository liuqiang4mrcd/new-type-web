{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["{projectRoot}/**/*", "!{projectRoot}/**/*.md"]
    },
    "test": {
      "dependsOn": ["build"],
      "cache": true,
      "inputs": ["{projectRoot}/**/*", "!{projectRoot}/**/*.md"]
    },
    "lint": {
      "cache": true
    }
  },
  "defaultBase": "main"
}
